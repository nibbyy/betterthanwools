{
  "multipart": [
    {
      "apply": {
        "model": "betterthanwools:block/green_bedroll_base"
      }
    },
    {
      "when": { "part": "head", "facing": "south" },
      "apply": { "model": "betterthanwools:block/green_bedroll_pillow" }
    },
    {
      "when": { "part": "head", "facing": "west" },
      "apply": { "model": "betterthanwools:block/green_bedroll_pillow", "y": 90 }
    },
    {
      "when": { "part": "head", "facing": "north" },
      "apply": { "model": "betterthanwools:block/green_bedroll_pillow", "y": 180 }
    },
    {
      "when": { "part": "head", "facing": "east" },
      "apply": { "model": "betterthanwools:block/green_bedroll_pillow", "y": 270 }
    }
  ]
}